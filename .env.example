# ============================================================
# Edifico - config instanta client (Docker). Copiaza in .env.
# ============================================================

# --- Baza de date ---
# Implicit SQLite pe volum (zero-config, ok pentru clienti mici).
DATABASE_URL=sqlite:////app/data/edifico.db
# Recomandat in cloud / la trafic mai mare (vezi docker-compose, Faza 1):
# DATABASE_URL=postgresql+psycopg2://edifico:PAROLA@db:5432/edifico_client

# --- Securitate ---
# GENEREAZA unic per client:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SCHIMBA_MA

# --- Admin initial (creat la primul start, doar daca nu exista) ---
ADMIN_EMAIL=admin@client.ro
ADMIN_PASSWORD=SCHIMBA_MA
ADMIN_NUME=Admin
ADMIN_PRENUME=Client

# --- Module cumparate = feature flags activate (separate prin virgula) ---
# Ex: controale-contract,controale-contract-import-msproject,bim-viewer-3d,bim-clash-detection
FEATURE_FLAGS=

# --- Mapbox (optional, pentru Locatii) ---
MAPBOX_PUBLIC_TOKEN=
MAPBOX_SECRET_TOKEN=

# --- Server ---
PORT=8000
WORKERS=1
THREADS=8

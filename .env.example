# ============================================================
# Edifico - config instanta client (Docker). Copiaza in .env.
# ============================================================

# --- Identitate client (pentru docker-compose + routing Traefik) ---
CLIENT_SLUG=client1
CLIENT_DOMAIN=client1.edifico.space

# --- Baza de date ---
# Sub docker-compose (Faza 1) DATABASE_URL e construit AUTOMAT din POSTGRES_*
# de mai jos si suprascris -> nu trebuie sa-l setezi aici.
# Linia de mai jos conteaza DOAR pentru `docker run` standalone (Faza 0, SQLite):
DATABASE_URL=sqlite:////app/data/edifico.db

# Postgres (folosit de docker-compose):
POSTGRES_USER=edifico
POSTGRES_PASSWORD=SCHIMBA_MA
POSTGRES_DB=edifico

# --- Securitate ---
# GENEREAZA unic per client:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=SCHIMBA_MA

# --- Admin initial (creat la primul start, doar daca nu exista) ---
ADMIN_EMAIL=admin@client.ro
ADMIN_PASSWORD=SCHIMBA_MA
ADMIN_NUME=Admin
ADMIN_PRENUME=Client

# --- Module cumparate = feature flags activate (separate prin virgula) ---
# Ex: controale-contract,controale-contract-import-msproject,bim-viewer-3d,bim-clash-detection
FEATURE_FLAGS=

# --- Mapbox (optional, pentru Locatii) ---
MAPBOX_PUBLIC_TOKEN=
MAPBOX_SECRET_TOKEN=

# --- Sentry (optional, Faza 3) - lasa gol ca sa fie dezactivat ---
SENTRY_DSN=
SENTRY_ENV=production

# --- Server ---
PORT=8000
WORKERS=1
THREADS=8
